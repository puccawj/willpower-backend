DATABASE_URL=postgres://willpower:willpower@localhost:5432/willpower
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h
PORT=3000
# The API's own public base URL, used to build uploaded-file links (e.g. https://api.wpusa.online).
# Required in production — without it, uploaded file URLs are built from the incoming request's
# host/protocol, which breaks behind a reverse proxy and bakes in whichever host the uploader
# happened to hit the API through.
PUBLIC_URL=
# OAuth Client ID from https://console.cloud.google.com/apis/credentials — must also be set in the
# frontend environment.ts files as googleClientId (same value, it's a public identifier).
GOOGLE_CLIENT_ID=
# App ID from https://developers.facebook.com/apps — must also be set in the frontend
# environment.ts files as facebookAppId (same value, it's a public identifier).
FACEBOOK_APP_ID=
# Comma-separated extra allowed CORS origins (e.g. a custom domain in front of Vercel).
# localhost/127.0.0.1 (any port) and *.vercel.app are already allowed by default.
CORS_ORIGIN=
# Secret key from https://dash.cloudflare.com/?to=/:account/turnstile — verifies the CAPTCHA
# token the login forms send. Leave blank to disable CAPTCHA verification (e.g. local dev) —
# the matching public site key goes in the frontend environment.ts files as turnstileSiteKey.
TURNSTILE_SECRET_KEY=
